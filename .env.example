# ===========================================
# API Keys — copy this file to .env and fill in your keys
# ===========================================

# LLM Providers (you need at least ONE)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Search (for Project 1 onwards)
TAVILY_API_KEY=tvly-...

# Observability (Project 7 onwards)
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agents-learning

# Optional: Langfuse (alternative to LangSmith)
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com
